{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "state/prd-created.json",
  "title": "PRD Created Message",
  "description": "Notification that a new PRD has been created",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "prd-created"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "device_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "properties": {
        "prd": {
          "type": "object",
          "description": "The newly created PRD"
        }
      },
      "required": ["prd"],
      "additionalProperties": false
    }
  },
  "required": ["type", "id", "device_id", "timestamp", "payload"],
  "additionalProperties": false
}
