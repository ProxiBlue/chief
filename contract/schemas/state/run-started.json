{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "state/run-started.json",
  "title": "Run Started Message",
  "description": "Notification that a run has started execution",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "run-started"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "device_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "properties": {
        "run": {
          "type": "object",
          "description": "The run that has started"
        }
      },
      "required": ["run"],
      "additionalProperties": false
    }
  },
  "required": ["type", "id", "device_id", "timestamp", "payload"],
  "additionalProperties": false
}
