{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "state/run-stopped.json",
  "title": "Run Stopped Message",
  "description": "Notification that a run has been stopped or cancelled",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "run-stopped"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "device_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "properties": {
        "run_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the run that was stopped"
        },
        "prd_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the parent PRD"
        },
        "reason": {
          "type": "string",
          "description": "Reason the run was stopped"
        }
      },
      "required": ["run_id", "prd_id"],
      "additionalProperties": false
    }
  },
  "required": ["type", "id", "device_id", "timestamp", "payload"],
  "additionalProperties": false
}
