{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "state/prd-deleted.json",
  "title": "PRD Deleted Message",
  "description": "Notification that a PRD has been deleted",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "prd-deleted"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "device_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "properties": {
        "prd_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the deleted PRD"
        },
        "project_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the parent project"
        }
      },
      "required": ["prd_id", "project_id"],
      "additionalProperties": false
    }
  },
  "required": ["type", "id", "device_id", "timestamp", "payload"],
  "additionalProperties": false
}
