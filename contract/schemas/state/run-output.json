{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "state/run-output.json",
  "title": "Run Output Message",
  "description": "Stdout or stderr output from an active run",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "run-output"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "device_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "properties": {
        "run_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the run"
        },
        "stream": {
          "type": "string",
          "enum": ["stdout", "stderr"],
          "description": "Output stream type"
        },
        "data": {
          "type": "string",
          "description": "Output data"
        }
      },
      "required": ["run_id", "stream", "data"],
      "additionalProperties": false
    }
  },
  "required": ["type", "id", "device_id", "timestamp", "payload"],
  "additionalProperties": false
}
