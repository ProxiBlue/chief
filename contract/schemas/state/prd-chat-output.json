{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "state/prd-chat-output.json",
  "title": "PRD Chat Output Message",
  "description": "Chat output generated during PRD processing",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "prd-chat-output"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "device_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "properties": {
        "prd_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the PRD this chat belongs to"
        },
        "role": {
          "type": "string",
          "enum": ["user", "assistant", "system"],
          "description": "Role of the chat message sender"
        },
        "content": {
          "type": "string",
          "description": "Chat message content"
        }
      },
      "required": ["prd_id", "role", "content"],
      "additionalProperties": false
    }
  },
  "required": ["type", "id", "device_id", "timestamp", "payload"],
  "additionalProperties": false
}
