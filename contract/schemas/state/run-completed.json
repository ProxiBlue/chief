{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "state/run-completed.json",
  "title": "Run Completed Message",
  "description": "Notification that a run has finished execution",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "run-completed"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "device_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "properties": {
        "run_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the completed run"
        },
        "prd_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the parent PRD"
        },
        "status": {
          "type": "string",
          "enum": ["completed", "failed"],
          "description": "Final run status"
        },
        "result": {
          "type": "string",
          "description": "Run result summary"
        },
        "error": {
          "type": "string",
          "description": "Error message if the run failed"
        },
        "finished_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when the run finished"
        }
      },
      "required": ["run_id", "prd_id", "status", "result"],
      "additionalProperties": false
    }
  },
  "required": ["type", "id", "device_id", "timestamp", "payload"],
  "additionalProperties": false
}
