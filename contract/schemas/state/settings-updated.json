{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "state/settings-updated.json",
  "title": "Settings Updated Message",
  "description": "Notification that device settings have changed",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "settings-updated"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "device_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "properties": {
        "settings": {
          "type": "object",
          "description": "The updated settings object"
        }
      },
      "required": ["settings"],
      "additionalProperties": false
    }
  },
  "required": ["type", "id", "device_id", "timestamp", "payload"],
  "additionalProperties": false
}
