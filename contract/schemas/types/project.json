{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "types/project.json",
  "title": "Project",
  "description": "A project tracked by the CLI agent",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique project identifier"
    },
    "path": {
      "type": "string",
      "description": "Absolute filesystem path to the project root"
    },
    "name": {
      "type": "string",
      "description": "Human-readable project name"
    },
    "git_remote": {
      "type": "string",
      "description": "Git remote URL"
    },
    "git_branch": {
      "type": "string",
      "description": "Current git branch"
    },
    "git_sha": {
      "type": "string",
      "description": "Current git commit SHA"
    },
    "git_status": {
      "type": "string",
      "enum": ["clean", "dirty"],
      "description": "Working tree status"
    },
    "last_commit": {
      "type": "object",
      "properties": {
        "sha": { "type": "string" },
        "message": { "type": "string" },
        "author": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["sha"],
      "additionalProperties": false,
      "description": "Most recent git commit"
    }
  },
  "required": ["id", "path", "name"],
  "additionalProperties": false
}
