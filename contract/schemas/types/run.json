{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "types/run.json",
  "title": "Run",
  "description": "A single execution run of a PRD story or task",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique run identifier"
    },
    "prd_id": {
      "type": "string",
      "format": "uuid",
      "description": "ID of the parent PRD"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "running", "completed", "failed", "cancelled"],
      "description": "Current run status"
    },
    "result": {
      "type": "string",
      "description": "Run result summary"
    },
    "error": {
      "type": "string",
      "description": "Error message if the run failed"
    },
    "started_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the run started"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the run finished"
    }
  },
  "required": ["id", "prd_id", "status"],
  "additionalProperties": false
}
